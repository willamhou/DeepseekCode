{
  "name": "deepseek-code",
  "displayName": "DeepseekCode",
  "description": "Run DeepseekCode CLI tasks from VS Code.",
  "version": "0.1.0",
  "publisher": "deepseekcode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:deepseek.quickAction",
    "onCommand:deepseek.openChat",
    "onCommand:deepseek.runTask",
    "onCommand:deepseek.explainSelection",
    "onCommand:deepseek.runBenchmark",
    "onCommand:deepseek.showDogfoodReport",
    "onView:deepseek.actions"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "deepseek.quickAction",
        "title": "DeepseekCode: Quick Action",
        "icon": "$(sparkle)"
      },
      {
        "command": "deepseek.openChat",
        "title": "DeepseekCode: Open Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "deepseek.runTask",
        "title": "DeepseekCode: Run Task",
        "icon": "$(terminal)"
      },
      {
        "command": "deepseek.explainSelection",
        "title": "DeepseekCode: Explain Selection",
        "icon": "$(symbol-method)"
      },
      {
        "command": "deepseek.runBenchmark",
        "title": "DeepseekCode: Run Benchmark",
        "icon": "$(beaker)"
      },
      {
        "command": "deepseek.showDogfoodReport",
        "title": "DeepseekCode: Show Dogfood Report",
        "icon": "$(graph)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "deepseek.explainSelection",
          "when": "editorHasSelection",
          "group": "navigation@90"
        },
        {
          "command": "deepseek.runTask",
          "group": "navigation@91"
        }
      ],
      "editor/title": [
        {
          "command": "deepseek.quickAction",
          "group": "navigation@90"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "deepseek.actions",
          "name": "DeepseekCode"
        }
      ]
    },
    "configuration": {
      "title": "DeepseekCode",
      "properties": {
        "deepseek.command": {
          "type": "string",
          "default": "deepseek",
          "description": "Command used to launch DeepseekCode. Use an absolute path or a wrapper such as `cargo run --bin deepseek --`."
        },
        "deepseek.maxSelectionChars": {
          "type": "number",
          "default": 6000,
          "minimum": 500,
          "description": "Maximum selected text characters sent to DeepseekCode task prompts."
        }
      }
    }
  }
}
